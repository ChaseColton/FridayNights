@page "/carrotGingerSoup"

<PageTitle>Carrot Ginger Soup</PageTitle>




<div class="text-center">

    @{

        var title = "Carrot Ginger Soup";
        var description = "Soups & Stews";
        var reference = "https://www.foodnetwork.com/recipes/ginger-carrot-soup-recipe-1915535";

        var ingredients = new string[]
        {
        "2 Tablespoons sweet cream butter",
        "2 onions, peeled and chopped",
        "2 Tablespoons garlic, chopped",
        "6 cups chicken broth",
        "2 pounds carrots, peeled and sliced",
        "2 Tablespoons grated fresh ginger",
        "1 cup whipping cream",
        "Salt and white pepper",
        "Sour cream",
        "Parsley sprigs (for garnish)"
        };

        var steps = new string[]
        {
        "In a 6-quart pan, over medium high heat, add butter and onions and cook, stirring often, until onions are limp.",
        "Add broth, carrots, and ginger. Cover and bring to a boil. Reduce heat and simmer until carrots are tender when pierced.",
        "Blend with immersion blender OR remove from heat and transfer to a blender. " +
        "Don't fill the blender more than half way, and do it in batches if you have to.  " +
        "Pulse the blender to start it, then puree until smooth.  " +
        "PLEASE be careful blending hot liquids - you can get badly burned! ",
        "Return to the pan and add cream, stir over high heat until hot.",
        "For a smoother flavor bring soup to a boil, add salt and pepper, to taste.",
        "Ladle into bowls and garnish with dollop sour cream and parsley sprigs."
        };
    }
</div>



<body>
    <div>
        <h1>@title</h1>
        <p></p>

        <h5>Description:</h5>
        <div>@description</div>
        <p></p>


        <h5>Ingredients:</h5>
        <div>
            <ul>
                @foreach (var ingredient in ingredients)
                {
                    <li>@ingredient</li>
                }
            </ul>
        </div>

        <h5>Steps:</h5>
        <div>
            <ol>
                @foreach (var step in steps)
                {
                    <li>@step</li>
                }
            </ol>
        </div>

        <a href=@reference>Reference</a>

    </div>
</body>
